{
  "manifest_version": 3,
  "name": "ExamGuard",
  "version": "1.1.0",
  "description": "Sınav güvenlik izleme sistemi",

  "permissions": [
    "tabs",
    "activeTab",
    "management",
    "storage",
    "scripting",
    "windows",
    "alarms",
    "history"
  ],

  "host_permissions": [
    "https://moodle.erzurum.edu.tr/*",
    "http://localhost:5000/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ExamGuard"
  }
}
